{
  "name": "pdlc-template-angular-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "ng serve",
    "build": "ng build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint \"src/**/*.ts\" --max-warnings=0",
    "lint:powershell": "pwsh -NoProfile -File ./scripts/ci/Test-PowerShellSyntax.ps1",
    "architecture": "pwsh ./scripts/ci/Test-ArchitectureBoundaries.ps1",
    "context": "pwsh ./scripts/ci/Test-ContextDocs.ps1",
    "changes": "pwsh ./scripts/ci/Test-ChangeDocs.ps1",
    "ci": "npm run lint && npm run lint:powershell && npm run architecture && npm run context && npm run changes && npm test && npm run build"
  },
  "dependencies": {
    "@angular/animations": "^20.0.0",
    "@angular/common": "^20.0.0",
    "@angular/compiler": "^20.0.0",
    "@angular/core": "^20.0.0",
    "@angular/forms": "^20.0.0",
    "@angular/platform-browser": "^20.0.0",
    "@angular/router": "^20.0.0",
    "@angular-architects/native-federation": "latest",
    "@softarc/sheriff-core": "latest",
    "rxjs": "^7.8.0",
    "tslib": "^2.8.0",
    "zone.js": "^0.15.0"
  },
  "devDependencies": {
    "@angular/build": "^20.0.0",
    "@angular/cli": "^20.0.0",
    "@angular/compiler-cli": "^20.0.0",
    "@eslint/js": "^9.39.1",
    "@softarc/eslint-plugin-sheriff": "latest",
    "@types/node": "latest",
    "eslint": "^9.39.1",
    "jsdom": "latest",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.48.0",
    "vitest": "^3.2.4"
  }
}
